# 运行环境：development | production | test
NODE_ENV=development

# ========== 数据库配置 ==========
# MySQL 连接串，格式：mysql://用户名:密码@主机:端口/数据库名
DATABASE_URL=mysql://monitor:monitor_pass@localhost:3306/codex_monitor

# ========== Redis 配置 ==========
# Redis 用于 Worker 任务队列和接口限流缓存
REDIS_HOST=localhost
REDIS_PORT=6379

# ========== 安全与认证 ==========
# JWT 签名密钥，用于 SDK 上报数据时的身份验证，生产环境必须替换为随机长字符串
JWT_SECRET=replace-with-a-long-random-secret

# ========== 服务端口 ==========
# 后端 API 服务监听端口
SERVER_PORT=3000
# 前端控制台地址，用于 CORS 跨域白名单配置
CLIENT_ORIGIN=http://localhost:5173

# ========== 邮件告警配置 ==========
# 用于发送异常告警和性能告警邮件，留空则不发送邮件
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=monitor@example.com

# ========== 前端 API 地址 ==========
# 前端控制台调用后端 API 的基础路径
VITE_API_BASE_URL=http://localhost:3000/api
